# Ancore Mobile Wallet Environment Variables

# Indexer Service
# GraphQL endpoint for blockchain data queries
EXPO_PUBLIC_INDEXER_URL=http://localhost:8080

# Relayer Service
# HTTP endpoint for transaction relay operations
EXPO_PUBLIC_RELAYER_URL=http://localhost:3001

# AI Agent Service
# HTTP endpoint for natural language intent parsing
EXPO_PUBLIC_AI_AGENT_URL=http://localhost:3002

# Environment
# NODE_ENV=development
